# Copy these values into Streamlit Community Cloud -> App -> Settings -> Secrets.
# Do not commit a real secrets.toml file.

# Optional. If omitted, the app chooses OpenAI first when OPENAI_API_KEY exists,
# then Gemini when GEMINI_API_KEY exists, then local rules.
VOICESCOPE_PROVIDER = "OpenAI"

OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-5-mini"

GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-2.5-flash"
